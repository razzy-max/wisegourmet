# Server
PORT=5001
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/wise-gourmet

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5173

# Paystack test keys (same as current project if you want)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Web Push (generate VAPID keys before enabling)
WEB_PUSH_SUBJECT=mailto:support@wisegourmet.app
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# Delivery fee rules
# DELIVERY_MODE defaults to zone logic in current MVP flow
DELIVERY_ZONE_FEES={"zone_a":700,"zone_b":1000,"zone_c":1500,"outside":2000}
DELIVERY_DISTANCE_BANDS=[{"maxKm":3,"fee":700},{"maxKm":6,"fee":1200},{"maxKm":10,"fee":1800},{"maxKm":"Infinity","fee":2500}]

# Seed users
SEED_DEFAULT_PASSWORD=ChangeMe123!
SEED_ADMIN_EMAIL=admin@wisegourmet.test
SEED_STAFF_EMAIL=staff@wisegourmet.test
SEED_RIDER_EMAIL=rider@wisegourmet.test
